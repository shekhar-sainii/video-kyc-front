# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API base URL
VITE_AUTH_SERVICE_URL=http://localhost:5000/api/v1
VITE_PRODUCT_SERVICE_URL=http://localhost:5000/api/v1

# Google OAuth Client ID (for Google sign-in on the frontend)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Never put server-side secrets here.
